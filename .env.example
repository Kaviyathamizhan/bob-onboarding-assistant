# Environment Variables Template
# Copy this file to backend/.env and fill in the actual values

# Required: Authenticate with IBM Bob API (provided at kickoff)
IBM_BOB_API_KEY=

# Optional: Higher GitHub API rate limits
GITHUB_TOKEN=

# Backend server port (default: 8000)
PORT=8000

# Path for temporarily cloned repos (default: system temp — avoids uvicorn reload on clone)
TEMP_DIR=

# Frontend Axios base URL pointing to backend
VITE_API_URL=http://localhost:8000
